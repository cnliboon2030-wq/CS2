def numericalgrade_togwa(grade):
    if grade >= 96 : 
        return 1.00
    elif grade >= 90 :
        return 1.25
    elif grade >= 84 :
        return 1.50
    elif grade >= 78 : 
        return 1.75
    elif grade >= 72 :
        return 2.00
    elif grade >= 66 :
        return 2.25
    elif grade >= 60 :
        return 2.50
    elif grade >= 55 :
        return 2.75
    elif grade >= 50 :
        return 3.00
    elif grade >= 40 :
        return 4.00
    else :
        return 5.00

def gwa_tonumericalgrade(gwa):
    if gwa >= 1.00 : 
        return 98
    elif gwa >= 1.25 :
        return 93
    elif gwa >= 1.50 :
        return 87
    elif gwa >= 1.75 : 
        return 81
    elif gwa >= 2.00 :
        return 75
    elif gwa >= 2.25 :
        return 69
    elif gwa >= 2.50 :
        return 63
    elif gwa >= 2.75 :
        return 58
    elif gwa >= 3.00 :
        return 53
    elif gwa >= 4.00 :
        return 45
    else :
        return 20

