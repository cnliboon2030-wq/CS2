def input_subjects():
    for i in range(no_of_subjects):  # Loop through each subject
        subject_id = input(f"Enter subject ID of subject {i+1}: ")
            
        subject_name = input(f"Enter name of subject {i+1}: ")
        # Store values
        if grade_condition == '1':
            units = 1 # Default unit = 1 for numerical grading
        else:
            while True:
                units = input(f"Enter units of {subject_name}: ")
                try:
                    units = float(units)
                except ValueError:
                    print("Invalid unit input! Not a number.")
        subject_list.append([subject_id, subject_name, units])

def input_students():
    for i in range(no_of_students):  # Loop through each subject
        student_id = input(f"Enter student ID for student {i+1}: ")
        student_name = input(f"Enter name of student {student_id}: ")
        student_list.append([student_id, student_name])

def input_grade():
    for student in student_list:
        studentfiles = []
        for q in range(1, 5):
            qtrstudentfiles = []
            for i in range(no_of_subjects):
                while True:
                    try:
                        grade = float(input(f"Enter grade of {student[1]} for {subject_list[i][1]} in quarter {q}: "))
                        if grade_condition == "1":
                            if 0 <= grade <= 100:
                                break
                            else:
                                print("Grade must be between 0-100.")
                        if grade_condition == "2":
                            if grade == 4 or grade == 5:
                                break
                            for g in range (1, 3.1, 0.25):
                                if grade == g:
                                    break
                            else:
                                print("Grade must be between 1.00 - 5.00.")
                    except ValueError:
                        print("Invalid grade input! Not a number.")
                    # Store values
                qtrstudentfiles.append(grade)
            studentfiles.append(qtrstudentfiles)
        classfiles.append([student[0], studentfiles])

def calculate_averages():
    for student in classfiles:
        for x in range(4):
            totalqtrgrade = 0
            for i in range(no_of_subjects):
                totalqtrgrade += student[1][x][i]
            qtravg = totalqtrgrade / no_of_subjects
            student[1][x].append(qtravg)
        averages = []
        for i in range(no_of_subjects):
            totalgrade = 0
            totalunits = 0
            for x in range(4):
                totalgrade += student[1][x][i]
                totalunits += subject_list[i][2]
            average = totalgrade / totalunits
            averages.append(average)
        student[1].append(averages)

